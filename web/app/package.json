{
  "name": "refactai-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p ${NEXT_PUBLIC_FRONTEND_PORT:-3001} -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p ${NEXT_PUBLIC_FRONTEND_PORT:-3001}",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test:research-sampling": "npx --yes tsx app/lib/__tests__/researchSampling.test.ts",
    "prepare:research-sample": "npx --yes tsx scripts/prepare-research-system-sample.ts",
    "export:all-research": "npx --yes tsx scripts/export-all-research-excel.ts",
    "export:extended-research": "npx --yes tsx scripts/export-extended-research-excel.ts",
    "export:frontier-master": "npx --yes tsx scripts/export-extended-research-excel.ts",
    "export:open-systems-raw": "npx --yes tsx scripts/export-open-systems-raw-excel.ts",
    "export:sheet-definitions": "npx --yes tsx scripts/export-excel-sheet-definitions.ts",
    "export:paper-pack": "npx --yes tsx scripts/export-paper-pack.ts",
    "export:rq3-behaviour": "npx --yes tsx scripts/export-rq3-behaviour.ts",
    "export:icse-dataset": "ICSE_DATASET_DESKTOP=1 npx --yes tsx scripts/export-paper-pack.ts --desktop",
    "verify:extended-research": "npx --yes tsx scripts/verify-extended-research-export.ts",
    "test:research-export": "npx --yes tsx app/lib/__tests__/researchExportCohort.test.mjs && npx --yes tsx app/lib/__tests__/researchAnalysisExports.test.mjs && npx --yes tsx app/lib/__tests__/researchCompleteCase.test.mjs && npx --yes tsx app/lib/__tests__/researchStatisticalAnalysis.test.mjs && npx --yes tsx app/lib/__tests__/researchRq3Behaviour.test.mjs && npx --yes tsx app/lib/__tests__/buildFullResearchExcel.test.mjs && npx --yes tsx app/lib/__tests__/buildCombinedFrontierMasterExcel.test.mjs && npx --yes tsx app/lib/__tests__/buildPaperReadyAnalysis.test.mjs && npx --yes tsx app/lib/__tests__/multiLlmExport.test.mjs && npx --yes tsx app/lib/__tests__/behavioralPassTestExport.test.mjs",
    "backfill:saved-reports": "npx --yes tsx scripts/backfill-missing-saved-reports.ts",
    "backfill:multi-llm": "npx --yes tsx scripts/backfill-multi-llm-to-saved-reports.ts",
    "audit:research": "bash ../scripts/audit-research-integrity.sh",
    "test:full-excel": "npx --yes tsx app/lib/__tests__/buildFullResearchExcel.test.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.2",
    "@monaco-editor/react": "^4.6.0",
    "@tanstack/react-query": "^5.8.4",
    "@tanstack/react-query-devtools": "^5.8.4",
    "@types/react-syntax-highlighter": "^15.5.13",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "diff": "^7.0.0",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.294.0",
    "monaco-editor": "^0.45.0",
    "next": "14.0.4",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.48.2",
    "react-syntax-highlighter": "^15.6.6",
    "recharts": "^2.8.0",
    "tailwind-merge": "^2.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-config-next": "14.0.4",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2"
  }
}
