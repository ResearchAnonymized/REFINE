# REFINE production ports (copy to config/ports.env)
FRONTEND_PORT=3001
BACKEND_PORT=8084
AGENTS_PORT=8092

# Agents → backend (set by start-refine.sh)
# BACKEND_BASE=http://127.0.0.1:8084/api

# Feature flags for REFINE production build
ENABLE_BASELINE_COMPARISON=0
ENABLE_RESEARCH_EXPORT_UI=0
NEXT_PUBLIC_ENABLE_BASELINE_COMPARISON=0
NEXT_PUBLIC_ENABLE_RESEARCH_EXPORT_UI=0
NEXT_PUBLIC_REFINE_DEMO=1
NEXT_PUBLIC_BRAND_NAME=REFINE
