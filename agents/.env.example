# OpenRouter (single key — routes to OpenAI, Google, Anthropic via model slugs)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR-API-KEY-HERE

# Optional: OpenRouter endpoint override
# OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions

# Default single-LLM model (OpenRouter slug)
# OPENROUTER_MODEL=anthropic/claude-opus-4.8

# Research multi-LLM chain — OpenRouter model slugs per provider
# OPENROUTER_MODEL_OPENAI=openai/gpt-5.5
# OPENROUTER_MODEL_GOOGLE=google/gemini-3.1-pro-preview
# OPENROUTER_MODEL_CLAUDE=anthropic/claude-opus-4.8

# ── Direct provider APIs (optional — bypass OpenRouter) ──
# LLM_ROUTING=auto          # auto | openrouter | direct
#   auto       = use direct API when provider key is set, else OpenRouter
#   openrouter = always OpenRouter (one key, all models)
#   direct     = always native APIs (requires per-provider keys)

# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# GOOGLE_API_KEY=...
# GOOGLE_MODEL=gemini-2.0-flash

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Multi-LLM agent mode: off (default) | full
# full = Planner + Refactorer + Verifier LLM agents per pass
# See config/multi-agent.env.example
# MULTI_LLM_AGENT_MODE=full

# Optional: Override backend URL
# BACKEND_BASE=http://localhost:8084/api

# Optional: Override port
# PORT=8092
